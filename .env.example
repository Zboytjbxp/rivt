PORT=8787
APP_NAME=RIVT
APP_SLUG=rivt

# Required managed storage. Local data/file fallback is intentionally disabled.
DATABASE_URL=
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SIGNED_URL_SECONDS=900
MAX_UPLOAD_MB=10

# Required before charging or verifying real users.
STRIPE_SECRET_KEY=
STRIPE_CHECKOUT_URL=
IDENTITY_PROVIDER_KEY=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Preferred for production SMS. Twilio Messaging Service SID (MG...)
TWILIO_MESSAGING_SERVICE_SID=
# Fallback during setup if you are sending directly from a number.
TWILIO_PHONE_NUMBER=
